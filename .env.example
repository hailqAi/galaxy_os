POSTGRES_DB=galaxy_os
POSTGRES_USER=galaxy
POSTGRES_PASSWORD=galaxy_local
POSTGRES_PORT=5432
REDIS_PORT=6379
DATABASE_URL=postgresql://galaxy:galaxy_local@localhost:5432/galaxy_os?schema=public
API_PORT=3001
NODE_ENV=development
ALLOW_DEV_AUTH=false
DEV_AUTH_USER_EMAIL=admin@galaxy.local
# Noninteractive test automation only; pass to one process, never store here.
# ADMIN_TEMP_PASSWORD=
# ADMIN_CONFIRM_EMAIL=admin@galaxy.local
DEV_SEED_PASSWORD=change-this-local-password
SESSION_COOKIE_NAME=galaxy_session
SESSION_TTL_HOURS=168
SESSION_IDLE_MINUTES=60
AVATAR_STORAGE_PATH=.local/avatars
AVATAR_MAX_BYTES=2097152
WEB_ORIGIN=http://localhost:3000
PASSWORD_BCRYPT_ROUNDS=12
APP_BASE_URL=http://localhost:3000
PASSWORD_RESET_TTL_MINUTES=30
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
EMAIL_FROM=no-reply@galaxy.local
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
