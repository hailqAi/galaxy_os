generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  active
  disabled
}

enum UserStatus {
  invited
  active
  disabled
}

enum MembershipStatus {
  active
  disabled
}

enum RecordStatus {
  active
  archived
}

enum AdministrationScope {
  SYSTEM
  SELF
  MANAGED_DEPARTMENTS
  ORGANIZATION
}

enum AssignmentScope {
  SYSTEM
  ORGANIZATION
  DEPARTMENT
  SELF
}

enum OrganizationalUnitType {
  BOARD
  DIVISION
  DEPARTMENT
  TEAM
  OTHER
}

enum RoleCategory {
  SYSTEM
  ORGANIZATION
  EXECUTIVE
  DEPARTMENT
  STANDARD
  CUSTOM
}

enum SettingScope {
  SYSTEM
  ORGANIZATION
}

enum CustomFieldEntityType {
  USER
  ORGANIZATION_MEMBER
  DEPARTMENT
  ROLE
}

enum CustomFieldDataType {
  TEXT
  LONG_TEXT
  NUMBER
  BOOLEAN
  DATE
  DATETIME
  SINGLE_SELECT
  MULTI_SELECT
  EMAIL
  PHONE
  URL
}

model Organization {
  id                String                   @id @default(uuid()) @db.Uuid
  name              String
  slug              String                   @unique
  timezone          String
  defaultCurrency   String
  status            OrganizationStatus       @default(active)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  memberships       OrganizationMembership[]
  departments       Department[]
  departmentMembers DepartmentMembership[]
  roles             Role[]
  userRoles         UserRole[]
  auditLogs         AuditLog[]
  settings          OrganizationSetting[]
  customFields      CustomFieldDefinition[]
}

model User {
  id                  String                   @id @default(uuid()) @db.Uuid
  email               String                   @unique
  normalizedEmail     String                   @unique
  displayName         String
  avatarKey           String?
  phone               String?
  status              UserStatus               @default(invited)
  externalAuthId      String?                  @unique
  lastLoginAt         DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  organizationMembers OrganizationMembership[]
  departmentMembers   DepartmentMembership[]
  roles               UserRole[]               @relation("UserRoles")
  assignedRoles       UserRole[]               @relation("AssignedRoles")
  auditLogs           AuditLog[]
  credential          PasswordCredential?
  sessions            Session[]
  passwordResetTokens PasswordResetToken[]
  grantedManagement   ManagedDepartment[]      @relation("ManagedDepartmentCreator")
  createdRoles        Role[]                   @relation("RoleCreator")
  createdCustomFields CustomFieldDefinition[]  @relation("CustomFieldCreator")
  customData          Json                     @default("{}")
}

model PasswordCredential {
  userId             String    @id @db.Uuid
  passwordHash       String
  mustChangePassword Boolean   @default(true)
  passwordChangedAt  DateTime?
  failedLoginCount   Int       @default(0)
  lockedUntil        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id])
}

model Session {
  id                       String                 @id @default(uuid()) @db.Uuid
  userId                   String                 @db.Uuid
  organizationMembershipId String                 @db.Uuid
  tokenHash                String                 @unique
  expiresAt                DateTime
  revokedAt                DateTime?
  createdAt                DateTime               @default(now())
  lastSeenAt               DateTime               @default(now())
  user                     User                   @relation(fields: [userId], references: [id])
  organizationMembership   OrganizationMembership @relation(fields: [organizationMembershipId], references: [id])

  @@index([userId, expiresAt])
  @@index([organizationMembershipId, expiresAt])
}

model PasswordResetToken {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  revokedAt   DateTime?
  requestedAt DateTime  @default(now())
  requestIp   String?
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id])

  @@index([userId, expiresAt])
}

model OrganizationMembership {
  id                  String                 @id @default(uuid()) @db.Uuid
  organizationId      String                 @db.Uuid
  userId              String                 @db.Uuid
  status              MembershipStatus       @default(active)
  joinedAt            DateTime               @default(now())
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  administrationScope AdministrationScope    @default(SELF)
  organization        Organization           @relation(fields: [organizationId], references: [id])
  user                User                   @relation(fields: [userId], references: [id])
  departmentMembers   DepartmentMembership[] @relation("DepartmentOrganizationMembership")
  roles               UserRole[]             @relation("RoleOrganizationMembership")
  sessions            Session[]
  managedDepartments  ManagedDepartment[]
  managedUnits        Department[]           @relation("DepartmentManager")
  customData          Json                   @default("{}")

  @@unique([organizationId, userId])
  @@unique([organizationId, id])
  @@index([userId, status])
}

model Department {
  id                  String                  @id @default(uuid()) @db.Uuid
  organizationId      String                  @db.Uuid
  code                String
  name                String
  description         String?
  parentId            String?                 @db.Uuid
  unitType            OrganizationalUnitType  @default(DEPARTMENT)
  managerMembershipId String?                 @db.Uuid
  displayOrder        Int                     @default(0)
  status              RecordStatus            @default(active)
  customData          Json                    @default("{}")
  createdAt           DateTime                @default(now())
  updatedAt           DateTime                @updatedAt
  organization        Organization            @relation(fields: [organizationId], references: [id])
  members             DepartmentMembership[]  @relation("DepartmentMembers")
  managers            ManagedDepartment[]
  parent              Department?             @relation("DepartmentHierarchy", fields: [organizationId, parentId], references: [organizationId, id])
  children            Department[]            @relation("DepartmentHierarchy")
  manager             OrganizationMembership? @relation("DepartmentManager", fields: [organizationId, managerMembershipId], references: [organizationId, id])
  scopedRoles         UserRole[]

  @@unique([organizationId, code])
  @@unique([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, parentId, displayOrder])
}

model ManagedDepartment {
  id              String                 @id @default(uuid()) @db.Uuid
  organizationId  String                 @db.Uuid
  managerId       String                 @db.Uuid
  departmentId    String                 @db.Uuid
  status          RecordStatus           @default(active)
  createdAt       DateTime               @default(now())
  createdByUserId String?                @db.Uuid
  expiresAt       DateTime?
  includeChildren Boolean                @default(false)
  manager         OrganizationMembership @relation(fields: [organizationId, managerId], references: [organizationId, id])
  department      Department             @relation(fields: [organizationId, departmentId], references: [organizationId, id])
  createdBy       User?                  @relation("ManagedDepartmentCreator", fields: [createdByUserId], references: [id])

  @@unique([managerId, departmentId])
  @@index([organizationId, managerId, status])
}

model DepartmentMembership {
  id             String                 @id @default(uuid()) @db.Uuid
  organizationId String                 @db.Uuid
  departmentId   String                 @db.Uuid
  userId         String                 @db.Uuid
  isPrimary      Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  organization   Organization           @relation(fields: [organizationId], references: [id])
  department     Department             @relation("DepartmentMembers", fields: [organizationId, departmentId], references: [organizationId, id])
  user           User                   @relation(fields: [userId], references: [id])
  membership     OrganizationMembership @relation("DepartmentOrganizationMembership", fields: [organizationId, userId], references: [organizationId, userId])

  @@unique([departmentId, userId])
  @@index([organizationId, userId])
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  name        String
  description String
  module      String           @default("general")
  isProtected Boolean          @default(false)
  isDelegable Boolean          @default(true)
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model Role {
  id                 String           @id @default(uuid()) @db.Uuid
  organizationId     String           @db.Uuid
  code               String
  name               String
  description        String?
  category           RoleCategory     @default(CUSTOM)
  maximumScope       AssignmentScope  @default(DEPARTMENT)
  isSystem           Boolean          @default(false)
  isProtected        Boolean          @default(false)
  isDelegable        Boolean          @default(true)
  administrationTier Int              @default(0)
  createdByUserId    String?          @db.Uuid
  customData         Json             @default("{}")
  status             RecordStatus     @default(active)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  organization       Organization     @relation(fields: [organizationId], references: [id])
  permissions        RolePermission[]
  users              UserRole[]
  createdBy          User?            @relation("RoleCreator", fields: [createdByUserId], references: [id])

  @@unique([organizationId, code])
  @@unique([organizationId, id])
  @@index([organizationId, status])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
}

model UserRole {
  id               String                 @id @default(uuid()) @db.Uuid
  organizationId   String                 @db.Uuid
  userId           String                 @db.Uuid
  roleId           String                 @db.Uuid
  scopeType        AssignmentScope        @default(SELF)
  departmentId     String?                @db.Uuid
  status           RecordStatus           @default(active)
  expiresAt        DateTime?
  createdAt        DateTime               @default(now())
  assignedByUserId String?                @db.Uuid
  organization     Organization           @relation(fields: [organizationId], references: [id])
  user             User                   @relation("UserRoles", fields: [userId], references: [id])
  role             Role                   @relation(fields: [organizationId, roleId], references: [organizationId, id])
  assignedBy       User?                  @relation("AssignedRoles", fields: [assignedByUserId], references: [id])
  membership       OrganizationMembership @relation("RoleOrganizationMembership", fields: [organizationId, userId], references: [organizationId, userId])
  department       Department?            @relation(fields: [organizationId, departmentId], references: [organizationId, id])

  @@unique([organizationId, userId, roleId, scopeType, departmentId])
  @@index([organizationId, userId])
  @@index([organizationId, departmentId, status])
}

model SystemSetting {
  id              String   @id @default(uuid()) @db.Uuid
  key             String   @unique
  value           Json
  description     String?
  isDelegable     Boolean  @default(false)
  updatedByUserId String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model OrganizationSetting {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  key            String
  value          Json
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, key])
  @@index([organizationId])
}

model CustomFieldDefinition {
  id                   String                @id @default(uuid()) @db.Uuid
  scope                SettingScope
  organizationId       String?               @db.Uuid
  entityType           CustomFieldEntityType
  key                  String
  label                String
  description          String?
  dataType             CustomFieldDataType
  required             Boolean               @default(false)
  defaultValue         Json?
  options              Json?
  validation           Json?
  visibilityPermission String?
  editPermission       String?
  sortOrder            Int                   @default(0)
  status               RecordStatus          @default(active)
  createdByUserId      String?               @db.Uuid
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  organization         Organization?         @relation(fields: [organizationId], references: [id])
  createdBy            User?                 @relation("CustomFieldCreator", fields: [createdByUserId], references: [id])

  @@unique([scope, organizationId, entityType, key])
  @@index([scope, organizationId, entityType, status, sortOrder])
}

model AuditLog {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  actorUserId    String?      @db.Uuid
  action         String
  entityType     String
  entityId       String       @db.Uuid
  beforeData     Json?
  afterData      Json?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id])
  actor          User?        @relation(fields: [actorUserId], references: [id])

  @@index([organizationId, createdAt])
  @@index([organizationId, actorUserId])
  @@index([organizationId, action])
  @@index([organizationId, entityType])
}
