{
  "name": "galaxy-os",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter './apps/*' dev",
    "lint": "pnpm -r --if-present lint && services/document-ai/.venv/bin/ruff check services/document-ai",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test && services/document-ai/.venv/bin/pytest services/document-ai",
    "build": "pnpm -r --if-present build",
    "build:web": "pnpm --filter @galaxy/web build",
    "build:api": "pnpm --filter @galaxy/api build",
    "start:web": "pnpm --filter @galaxy/web start",
    "start:api": "pnpm --filter @galaxy/api start:production",
    "edge:build": "pnpm --filter @galaxy/edge build",
    "edge:start": "pnpm --filter @galaxy/edge start",
    "edge:test": "pnpm --filter @galaxy/edge test",
    "edge:check": "pnpm --filter @galaxy/edge check",
    "prod:start": "systemctl --user start galaxy-os.target",
    "prod:stop": "systemctl --user stop galaxy-os.target",
    "prod:health": "bash scripts/production-health.sh",
    "prod:verify-artifacts": "bash scripts/verify-production-artifacts.sh",
    "db:generate": "pnpm --filter @galaxy/api prisma:generate",
    "db:migrate": "pnpm --filter @galaxy/api prisma:migrate",
    "db:status": "pnpm --filter @galaxy/api prisma:status",
    "db:seed": "pnpm --filter @galaxy/api prisma:seed",
    "admin:reset-password": "pnpm --filter @galaxy/api admin:reset-password",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "env:check": "node scripts/check-environment.mjs"
  },
  "devDependencies": {
    "prettier": "3.6.2"
  }
}
